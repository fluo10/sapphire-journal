{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Rust (sapphire-journal)",
      "type": "shell",
      "command": "cargo build -p sapphire-journal",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "Copy binary to sapphire-journal-vscode/bin",
      "type": "shell",
      "command": "mkdir -p sapphire-journal-vscode/bin && cp target/debug/sajo sapphire-journal-vscode/bin/sajo",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Build Rust (sapphire-journal)",
      "problemMatcher": []
    },
    {
      "label": "Compile TypeScript (sapphire-journal-vscode)",
      "type": "shell",
      "command": "pnpm compile",
      "options": {
        "cwd": "${workspaceFolder}/sapphire-journal-vscode"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build All (Rust + TypeScript)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Copy binary to sapphire-journal-vscode/bin",
        "Compile TypeScript (sapphire-journal-vscode)"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Watch TypeScript (sapphire-journal-vscode)",
      "type": "shell",
      "command": "pnpm watch",
      "options": {
        "cwd": "${workspaceFolder}/sapphire-journal-vscode"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": "relative",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting compilation",
          "endsPattern": "Watching for file changes"
        }
      }
    }
  ]
}
