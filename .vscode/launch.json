{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (sapphire-journal-vscode)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/sapphire-journal-vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/sapphire-journal-vscode/out/**/*.js"
      ],
      "preLaunchTask": "Build All (Rust + TypeScript)"
    }
  ]
}
